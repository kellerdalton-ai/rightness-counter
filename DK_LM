<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Rightness Analytics Dashboard</title>
  <style>
    /* =========================================================
       RETRO ARCADE OFFICE RIVALRY DASHBOARD
       Mobile-optimized single-file HTML / CSS / JavaScript

       UPDATES IN THIS VERSION
       - Recent activity log starts/reset empty
       - Ducks are bigger, more animated, and more competitive
       - Ducks grow when they eat
       - Ducks race for food and steal snacks from each other
       - Leader duck / duck rivalry stats added
       ========================================================= */

    :root {
      --bg-main: #0a0d16;
      --bg-panel: #101728;
      --bg-panel-2: #0d1322;
      --grid: rgba(255,255,255,0.04);

      --dalton: #36f3ff;
      --dalton-dark: #0f8ea3;

      --liz: #ff5fd2;
      --liz-dark: #a12b7f;

      --accent: #ffe85c;
      --danger: #ff4d4d;
      --success: #6eff7c;
      --text: #eff6ff;
      --muted: #9db3d7;
      --border: #2a3554;

      --tap-size: 54px;
      --shadow: 0 0 18px rgba(255,255,255,0.08);
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
    }

    html, body {
      margin: 0;
      min-height: 100%;
      background:
        linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
        linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px),
        radial-gradient(circle at top, #18233d 0%, #0b1020 30%, #070a12 100%);
      background-size: 24px 24px, 24px 24px, auto;
      color: var(--text);
      font-family: "Courier New", Courier, monospace;
      overflow-x: hidden;
    }

    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        repeating-linear-gradient(
          to bottom,
          rgba(255,255,255,0.02),
          rgba(255,255,255,0.02) 1px,
          transparent 2px,
          transparent 4px
        );
      opacity: 0.3;
      mix-blend-mode: screen;
    }

    .app {
      width: min(1150px, calc(100% - 14px));
      margin: 0 auto;
      padding: 10px 0 28px;
      position: relative;
      z-index: 1;
    }

    .pixel-box {
      border: 4px solid var(--border);
      background:
        linear-gradient(180deg, rgba(255,255,255,0.04), transparent 14%),
        linear-gradient(180deg, var(--bg-panel), var(--bg-panel-2));
      box-shadow: var(--shadow);
      position: relative;
      overflow: hidden;
    }

    .pixel-box::after {
      content: "";
      position: absolute;
      inset: 0;
      pointer-events: none;
      border: 2px solid rgba(255,255,255,0.04);
    }

    .scanline {
      position: absolute;
      inset: 0;
      pointer-events: none;
      background: linear-gradient(
        to bottom,
        transparent 0%,
        rgba(255,255,255,0.08) 50%,
        transparent 100%
      );
      opacity: 0.08;
      animation: scan 5s linear infinite;
    }

    @keyframes scan {
      from { transform: translateY(-100%); }
      to { transform: translateY(100%); }
    }

    .blink {
      animation: blink 1.2s steps(2, start) infinite;
    }

    @keyframes blink {
      50% { opacity: 0.45; }
    }

    .glow-dalton {
      box-shadow:
        0 0 0 2px rgba(54,243,255,0.08),
        0 0 14px rgba(54,243,255,0.18),
        0 0 30px rgba(54,243,255,0.18);
    }

    .glow-liz {
      box-shadow:
        0 0 0 2px rgba(255,95,210,0.08),
        0 0 14px rgba(255,95,210,0.18),
        0 0 30px rgba(255,95,210,0.18);
    }

    .hidden {
      display: none !important;
    }

    /* =========================
       HEADER
       ========================= */
    .topbar {
      padding: 14px;
      margin-bottom: 12px;
      position: relative;
    }

    .header-row {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      align-items: flex-start;
      justify-content: space-between;
    }

    .title-wrap h1 {
      margin: 0;
      font-size: clamp(1.2rem, 5vw, 2.3rem);
      letter-spacing: 1.5px;
      text-transform: uppercase;
      text-shadow: 0 0 8px rgba(255,255,255,0.15);
      line-height: 1.15;
    }

    .title-wrap p {
      margin: 6px 0 0;
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.45;
      max-width: 820px;
    }

    .corp-badge {
      border: 3px solid var(--accent);
      color: var(--accent);
      padding: 8px 10px;
      font-size: 0.75rem;
      text-transform: uppercase;
      background: rgba(255, 232, 92, 0.08);
      text-shadow: 0 0 8px rgba(255, 232, 92, 0.35);
      white-space: nowrap;
    }

    .leader-banner {
      margin-top: 12px;
      padding: 12px;
      border: 3px solid var(--accent);
      background: rgba(255, 232, 92, 0.08);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: 1.2px;
      font-weight: bold;
      text-shadow: 0 0 8px rgba(255,232,92,0.35);
      font-size: clamp(0.85rem, 3vw, 1rem);
      line-height: 1.4;
    }

    .leader-banner strong {
      color: #fff8bf;
    }

    .status-strip {
      margin-top: 10px;
      display: grid;
      gap: 8px;
      grid-template-columns: 1fr;
    }

    .status-pill {
      border: 2px solid var(--border);
      padding: 10px;
      background: rgba(255,255,255,0.03);
      color: var(--text);
      font-size: 0.84rem;
      min-height: 42px;
      display: flex;
      align-items: center;
      line-height: 1.35;
    }

    .status-pill.warning {
      border-color: var(--danger);
      color: #ffd8d8;
      background: rgba(255, 77, 77, 0.08);
      box-shadow: 0 0 12px rgba(255, 77, 77, 0.18);
    }

    .status-pill.showdown {
      border-color: var(--accent);
      color: #fff3a4;
      background: rgba(255, 232, 92, 0.08);
      box-shadow: 0 0 14px rgba(255, 232, 92, 0.18);
      animation: pulse 1.1s infinite;
    }

    @keyframes pulse {
      0%, 100% { transform: scale(1); }
      50% { transform: scale(1.01); }
    }

    /* =========================
       LOCK PANEL
       ========================= */
    .lock-panel {
      margin-bottom: 12px;
      padding: 14px;
    }

    .lock-grid {
      display: grid;
      grid-template-columns: 1.15fr 0.85fr;
      gap: 12px;
      align-items: start;
    }

    .lock-panel h3 {
      margin: 0 0 10px;
      font-size: 0.98rem;
      text-transform: uppercase;
      letter-spacing: 1.2px;
    }

    .lock-copy {
      color: var(--muted);
      font-size: 0.9rem;
      line-height: 1.45;
      margin-bottom: 10px;
    }

    .unlock-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 8px;
      align-items: stretch;
    }

    .unlock-row input {
      width: 100%;
      min-height: var(--tap-size);
      background: rgba(255,255,255,0.04);
      border: 3px solid var(--border);
      color: var(--text);
      font: inherit;
      padding: 12px 12px;
      font-size: 1rem;
    }

    .unlock-row input:focus {
      outline: 3px dashed var(--accent);
      outline-offset: 2px;
      border-color: var(--accent);
    }

    .lock-status {
      margin-top: 10px;
      border: 2px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      padding: 10px;
      font-size: 0.88rem;
      line-height: 1.4;
    }

    .lock-status.ok {
      border-color: var(--success);
      color: var(--success);
      box-shadow: 0 0 10px rgba(110,255,124,0.18);
    }

    .lock-status.bad {
      border-color: var(--danger);
      color: #ffd6d6;
      background: rgba(255,77,77,0.08);
    }

    .admin-chip {
      display: inline-block;
      border: 2px solid var(--success);
      color: var(--success);
      padding: 6px 8px;
      text-transform: uppercase;
      font-size: 0.78rem;
      margin-bottom: 10px;
      background: rgba(110,255,124,0.06);
    }

    /* =========================
       SCOREBOARD
       ========================= */
    .scoreboard {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
      margin-bottom: 12px;
    }

    .score-card {
      padding: 14px;
      position: relative;
      min-height: 250px;
      transition: transform 0.15s ease, box-shadow 0.15s ease;
    }

    .score-card:hover {
      transform: translateY(-2px);
    }

    .score-card h2 {
      margin: 0 0 10px;
      text-transform: uppercase;
      letter-spacing: 1.1px;
      font-size: clamp(0.98rem, 3.8vw, 1.35rem);
      line-height: 1.25;
    }

    .score-meta {
      color: var(--muted);
      font-size: 0.84rem;
      margin-bottom: 12px;
      line-height: 1.42;
    }

    .score-value {
      font-size: clamp(3rem, 14vw, 6rem);
      line-height: 1;
      margin: 10px 0 14px;
      font-weight: bold;
      letter-spacing: 2px;
      text-shadow: 0 0 14px currentColor;
      word-break: break-word;
    }

    .dalton-card {
      border-color: rgba(54,243,255,0.4);
      background:
        linear-gradient(180deg, rgba(54,243,255,0.06), transparent 22%),
        linear-gradient(180deg, #0c1823, #0b1220);
    }

    .dalton-card h2,
    .dalton-card .score-value,
    .dalton-card .identity-badge {
      color: var(--dalton);
    }

    .liz-card {
      border-color: rgba(255,95,210,0.4);
      background:
        linear-gradient(180deg, rgba(255,95,210,0.06), transparent 22%),
        linear-gradient(180deg, #1b1020, #12101c);
    }

    .liz-card h2,
    .liz-card .score-value,
    .liz-card .identity-badge {
      color: var(--liz);
    }

    .identity-badge {
      display: inline-block;
      border: 2px solid currentColor;
      padding: 6px 10px;
      font-size: 0.72rem;
      text-transform: uppercase;
      margin-bottom: 8px;
      background: rgba(255,255,255,0.02);
      line-height: 1.35;
    }

    .controls {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 8px;
    }

    button {
      appearance: none;
      border: 3px solid var(--border);
      background: linear-gradient(180deg, #1b2742, #121a30);
      color: var(--text);
      font: inherit;
      min-height: var(--tap-size);
      padding: 12px 10px;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 1px;
      transition: transform 0.08s ease, filter 0.12s ease, border-color 0.12s ease, opacity 0.12s ease;
      position: relative;
      font-size: 0.88rem;
    }

    button:hover {
      filter: brightness(1.08);
      transform: translateY(-1px);
    }

    button:active {
      transform: translateY(1px);
    }

    button:focus-visible {
      outline: 3px dashed var(--accent);
      outline-offset: 3px;
    }

    button:disabled {
      cursor: not-allowed;
      opacity: 0.45;
      filter: grayscale(0.25);
      transform: none;
    }

    .btn-dalton {
      border-color: rgba(54,243,255,0.45);
      color: var(--dalton);
      text-shadow: 0 0 8px rgba(54,243,255,0.35);
      background: linear-gradient(180deg, rgba(54,243,255,0.12), rgba(54,243,255,0.05));
    }

    .btn-liz {
      border-color: rgba(255,95,210,0.45);
      color: var(--liz);
      text-shadow: 0 0 8px rgba(255,95,210,0.35);
      background: linear-gradient(180deg, rgba(255,95,210,0.12), rgba(255,95,210,0.05));
    }

    .btn-accent {
      border-color: rgba(255, 232, 92, 0.45);
      color: var(--accent);
      background: linear-gradient(180deg, rgba(255, 232, 92, 0.13), rgba(255, 232, 92, 0.04));
      text-shadow: 0 0 8px rgba(255,232,92,0.3);
    }

    .btn-success {
      border-color: rgba(110,255,124,0.4);
      color: var(--success);
      background: linear-gradient(180deg, rgba(110,255,124,0.13), rgba(110,255,124,0.04));
      text-shadow: 0 0 8px rgba(110,255,124,0.25);
    }

    .btn-reset {
      width: 100%;
      margin-top: 10px;
    }

    .locked-overlay {
      margin-top: 10px;
      border: 2px dashed rgba(255,255,255,0.16);
      background: rgba(255,255,255,0.03);
      padding: 8px 10px;
      color: var(--muted);
      font-size: 0.8rem;
      line-height: 1.4;
    }

    /* =========================
       LOWER PANELS
       ========================= */
    .dashboard-grid {
      display: grid;
      grid-template-columns: 1.02fr 0.98fr;
      gap: 12px;
      margin-top: 12px;
    }

    .panel {
      padding: 14px;
      min-height: 240px;
      position: relative;
    }

    .panel h3 {
      margin: 0 0 10px;
      font-size: 0.98rem;
      text-transform: uppercase;
      letter-spacing: 1.4px;
    }

    .sub-note {
      color: var(--muted);
      font-size: 0.88rem;
      margin-bottom: 10px;
      line-height: 1.45;
    }

    .activity-log {
      list-style: none;
      margin: 0;
      padding: 0;
      max-height: 290px;
      overflow: auto;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .activity-log li {
      border: 2px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      padding: 10px;
      line-height: 1.45;
      font-size: 0.88rem;
    }

    .activity-log .time {
      color: var(--muted);
      font-size: 0.76rem;
      display: inline-block;
      margin-left: 8px;
    }

    .activity-log .tag {
      display: inline-block;
      padding: 2px 7px;
      margin-right: 8px;
      border: 2px solid currentColor;
      font-size: 0.68rem;
      text-transform: uppercase;
      vertical-align: middle;
    }

    .tag.dalton { color: var(--dalton); }
    .tag.liz { color: var(--liz); }
    .tag.system { color: var(--accent); }

    .status-board {
      display: grid;
      gap: 8px;
    }

    .status-card {
      border: 2px solid rgba(255,255,255,0.08);
      background: rgba(255,255,255,0.03);
      padding: 10px;
    }

    .status-label {
      color: var(--muted);
      font-size: 0.76rem;
      margin-bottom: 6px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    .status-value {
      font-size: 0.9rem;
      line-height: 1.45;
    }

    .achievements {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 6px;
    }

    .badge {
      border: 2px solid var(--border);
      padding: 8px 9px;
      background: rgba(255,255,255,0.03);
      font-size: 0.76rem;
      text-transform: uppercase;
      color: var(--text);
      line-height: 1.3;
    }

    .badge.active {
      border-color: var(--success);
      color: var(--success);
      box-shadow: 0 0 10px rgba(110,255,124,0.18);
    }

    .shortcut-list {
      display: grid;
      gap: 6px;
      font-size: 0.82rem;
      color: var(--muted);
      line-height: 1.4;
    }

    kbd {
      border: 2px solid var(--border);
      background: rgba(255,255,255,0.04);
      padding: 2px 6px;
      font: inherit;
      color: var(--text);
    }

    /* =========================
       DUCK GAME
       ========================= */
    .duck-header {
      display: flex;
      justify-content: space-between;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }

    .duck-stats {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .duck-stat {
      border: 2px solid rgba(255,255,255,0.08);
      padding: 7px 9px;
      background: rgba(255,255,255,0.03);
      font-size: 0.78rem;
      color: var(--muted);
      text-transform: uppercase;
    }

    .duck-area-wrap {
      position: relative;
    }

    .duck-area {
      position: relative;
      height: 330px;
      border: 3px solid rgba(255,255,255,0.08);
      background:
        radial-gradient(circle at 50% 38%, rgba(255,255,255,0.12), transparent 25%),
        linear-gradient(180deg, #2b4d78 0 60%, #244823 60% 100%);
      overflow: hidden;
      touch-action: manipulation;
      user-select: none;
    }

    .duck-area::before {
      content: "";
      position: absolute;
      left: 0;
      right: 0;
      top: 58%;
      height: 16px;
      background:
        repeating-linear-gradient(
          90deg,
          rgba(255,255,255,0.14) 0 14px,
          rgba(255,255,255,0.04) 14px 28px
        );
      opacity: 0.4;
    }

    .duck-area::after {
      content: "";
      position: absolute;
      inset: auto 0 0 0;
      height: 28%;
      background:
        repeating-linear-gradient(
          90deg,
          rgba(38,81,32,0.15) 0 24px,
          rgba(24,57,20,0.08) 24px 48px
        );
      opacity: 0.6;
      pointer-events: none;
    }

    .duck-instructions {
      margin: 8px 0 0;
      color: var(--muted);
      font-size: 0.82rem;
      line-height: 1.45;
    }

    .food {
      position: absolute;
      width: 22px;
      height: 22px;
      transform: translate(-50%, -50%);
      font-size: 18px;
      pointer-events: none;
      animation: popFood 0.28s ease-out;
      text-align: center;
      line-height: 22px;
      text-shadow: 0 0 8px rgba(255,232,92,0.45);
    }

    @keyframes popFood {
      from { opacity: 0; transform: translate(-50%, -65%) scale(0.65); }
      to { opacity: 1; transform: translate(-50%, -50%) scale(1); }
    }

    .duck {
      position: absolute;
      width: 96px;
      height: 78px;
      transform: translate(-50%, -50%) scale(var(--duck-scale, 1));
      transform-origin: center center;
      image-rendering: pixelated;
      pointer-events: none;
      transition: left 0.1s linear, top 0.1s linear, filter 0.15s ease, transform 0.12s ease;
      filter: drop-shadow(0 6px 0 rgba(0,0,0,0.28));
    }

    .duck.flip {
      transform: translate(-50%, -50%) scaleX(-1) scale(var(--duck-scale, 1));
    }

    .duck.duck-champion {
      filter:
        drop-shadow(0 0 10px rgba(255, 232, 92, 0.35))
        drop-shadow(0 6px 0 rgba(0,0,0,0.28));
    }

    .duck.duck-rush {
      animation: duckRush 0.28s infinite alternate;
    }

    @keyframes duckRush {
      from { margin-top: 0; }
      to { margin-top: -2px; }
    }

    .duck-body {
      position: absolute;
      left: 10px;
      top: 22px;
      width: 54px;
      height: 30px;
      background: #ffd75a;
      border: 4px solid #342600;
      box-shadow: inset 0 -4px 0 rgba(0,0,0,0.08);
    }

    .duck-head {
      position: absolute;
      right: 10px;
      top: 10px;
      width: 26px;
      height: 26px;
      background: #ffd75a;
      border: 4px solid #342600;
    }

    .duck-eye {
      position: absolute;
      right: 7px;
      top: 8px;
      width: 4px;
      height: 4px;
      background: #111;
    }

    .duck-beak {
      position: absolute;
      right: -7px;
      top: 11px;
      width: 12px;
      height: 8px;
      background: #ff914d;
      border: 2px solid #7c3400;
    }

    .duck-wing {
      position: absolute;
      left: 20px;
      top: 22px;
      width: 18px;
      height: 12px;
      background: #f1b93e;
      border: 3px solid #342600;
    }

    .duck-foot {
      position: absolute;
      bottom: 7px;
      width: 7px;
      height: 7px;
      background: #ff914d;
      border: 1px solid #7c3400;
    }

    .duck-foot.left { left: 22px; }
    .duck-foot.right { left: 38px; }

    .duck-badge {
      position: absolute;
      top: -18px;
      left: 50%;
      transform: translateX(-50%);
      font-size: 11px;
      color: #fff6b6;
      text-transform: uppercase;
      white-space: nowrap;
      letter-spacing: 0.6px;
      text-shadow: 0 0 8px rgba(255,255,255,0.45);
    }

    .duck-happy {
      position: absolute;
      top: -20px;
      left: 50%;
      transform: translateX(-50%);
      color: #fff6b6;
      font-size: 13px;
      text-shadow: 0 0 8px rgba(255,255,255,0.4);
      animation: floatText 0.9s ease-out forwards;
      white-space: nowrap;
    }

    @keyframes floatText {
      from { opacity: 0; transform: translateX(-50%) translateY(8px); }
      to { opacity: 1; transform: translateX(-50%) translateY(-10px); }
    }

    .duck-spark {
      position: absolute;
      width: 10px;
      height: 10px;
      transform: translate(-50%, -50%);
      pointer-events: none;
      font-size: 12px;
      animation: sparkFly 0.6s ease-out forwards;
      text-shadow: 0 0 6px rgba(255,255,255,0.35);
    }

    @keyframes sparkFly {
      from { opacity: 1; transform: translate(-50%, -50%) scale(0.7); }
      to { opacity: 0; transform: translate(calc(-50% + var(--dx)), calc(-50% + var(--dy))) scale(1.2); }
    }

    /* =========================
       SHOWDOWN / SIREN
       ========================= */
    .showdown-mode {
      animation: showdownGlow 1.1s infinite alternate;
    }

    @keyframes showdownGlow {
      0% {
        box-shadow:
          0 0 0 2px rgba(255, 77, 77, 0.15),
          0 0 12px rgba(255, 77, 77, 0.18),
          0 0 24px rgba(255, 232, 92, 0.12);
      }
      100% {
        box-shadow:
          0 0 0 3px rgba(255, 77, 77, 0.22),
          0 0 18px rgba(255, 77, 77, 0.3),
          0 0 32px rgba(255, 232, 92, 0.2);
      }
    }

    .siren {
      position: absolute;
      top: 8px;
      right: 8px;
      font-size: 0.72rem;
      color: #ffd5d5;
      border: 2px solid var(--danger);
      padding: 5px 7px;
      background: rgba(255, 77, 77, 0.1);
      text-transform: uppercase;
      letter-spacing: 1px;
      box-shadow: 0 0 12px rgba(255, 77, 77, 0.18);
    }

    /* =========================
       CONFETTI / FLASH
       ========================= */
    .confetti-layer {
      position: fixed;
      inset: 0;
      overflow: hidden;
      pointer-events: none;
      z-index: 50;
    }

    .confetti {
      position: absolute;
      top: -20px;
      width: 8px;
      height: 14px;
      opacity: 0.95;
      animation: fall linear forwards;
    }

    @keyframes fall {
      to {
        transform: translateY(110vh) rotate(760deg);
        opacity: 1;
      }
    }

    .flash-overlay {
      position: fixed;
      inset: 0;
      background: rgba(255,255,255,0.1);
      opacity: 0;
      pointer-events: none;
      z-index: 40;
    }

    .flash-overlay.active {
      animation: flash 0.45s ease-out;
    }

    @keyframes flash {
      0% { opacity: 0.45; }
      100% { opacity: 0; }
    }

    /* =========================
       SECRET / TOAST
       ========================= */
    .secret-logo {
      position: absolute;
      top: 10px;
      right: 10px;
      width: 16px;
      height: 16px;
      border: 2px solid rgba(255,255,255,0.18);
      background: linear-gradient(45deg, var(--dalton) 0 50%, var(--liz) 50% 100%);
      cursor: pointer;
      opacity: 0.35;
      transition: opacity 0.15s ease, transform 0.15s ease;
    }

    .secret-logo:hover {
      opacity: 1;
      transform: scale(1.15) rotate(8deg);
    }

    .easter-toast {
      position: fixed;
      left: 50%;
      bottom: 12px;
      transform: translateX(-50%);
      border: 3px solid var(--accent);
      background: rgba(10,13,22,0.94);
      color: var(--accent);
      padding: 12px 14px;
      z-index: 60;
      text-transform: uppercase;
      letter-spacing: 1px;
      box-shadow: 0 0 20px rgba(255,232,92,0.18);
      display: none;
      width: min(94vw, 520px);
      text-align: center;
      font-size: 0.86rem;
      line-height: 1.4;
    }

    .easter-toast.show {
      display: block;
      animation: toastPop 2.2s ease forwards;
    }

    @keyframes toastPop {
      0% { opacity: 0; transform: translateX(-50%) translateY(10px); }
      10%, 80% { opacity: 1; transform: translateX(-50%) translateY(0); }
      100% { opacity: 0; transform: translateX(-50%) translateY(8px); }
    }

    .footer-note {
      margin-top: 12px;
      font-size: 0.76rem;
      color: var(--muted);
      text-align: center;
      opacity: 0.9;
      line-height: 1.45;
      padding: 0 4px;
    }

    /* =========================
       RESPONSIVE
       ========================= */
    @media (max-width: 980px) {
      .lock-grid,
      .dashboard-grid,
      .scoreboard {
        grid-template-columns: 1fr;
      }
    }

    @media (min-width: 681px) {
      .status-strip {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    @media (max-width: 680px) {
      .app {
        width: min(100% - 10px, 1150px);
        padding-top: 6px;
      }

      .topbar,
      .lock-panel,
      .score-card,
      .panel {
        padding: 12px;
      }

      .unlock-row {
        grid-template-columns: 1fr;
      }

      .controls {
        grid-template-columns: 1fr;
      }

      .corp-badge {
        width: 100%;
        text-align: center;
      }

      .duck-area {
        height: 270px;
      }

      .duck {
        width: 84px;
        height: 68px;
      }
    }

    @media (max-width: 420px) {
      :root {
        --tap-size: 50px;
      }

      .title-wrap p,
      .score-meta,
      .sub-note,
      .lock-copy {
        font-size: 0.82rem;
      }

      .duck-area {
        height: 240px;
      }

      .duck {
        width: 76px;
        height: 62px;
      }
    }
  </style>
</head>
<body>
  <div class="confetti-layer" id="confettiLayer"></div>
  <div class="flash-overlay" id="flashOverlay"></div>
  <div class="easter-toast" id="easterToast"></div>

  <main class="app">
    <header class="topbar pixel-box">
      <div class="scanline"></div>
      <div class="secret-logo" id="secretLogo" title="Definitely not a secret button"></div>

      <div class="header-row">
        <div class="title-wrap">
          <h1>Rightness Analytics Dashboard</h1>
          <p>
            Corporate-grade tracking of strategic correctness, disputed memory, and ongoing office legend status.
            Now with score lock controls and aggressively overachieving competitive ducks.
          </p>
        </div>
        <div class="corp-badge blink">Quarterly Rivalry Metrics v8-BIT</div>
      </div>

      <div class="leader-banner" id="leaderBanner">
        Initializing executive rightness forecast...
      </div>

      <div class="status-strip">
        <div class="status-pill" id="closeMatchPill">Gap Analysis Pending</div>
        <div class="status-pill" id="differencePill">Difference: 0</div>
        <div class="status-pill" id="funnyStatus">Awaiting first ruling from the committee.</div>
      </div>
    </header>

    <section class="lock-panel pixel-box">
      <div class="scanline"></div>
      <div class="lock-grid">
        <div>
          <h3>Score Update Access Control</h3>
          <div class="lock-copy">
            Enter the administrative update code to unlock score changes. This helps prevent casual hallway taps,
            opportunistic bias, and unauthorized acts of narrative revision.
          </div>

          <div class="unlock-row">
            <input
              id="codeInput"
              type="password"
              inputmode="numeric"
              autocomplete="off"
              placeholder="Enter admin code"
              aria-label="Enter admin code"
            />
            <button class="btn-success" id="unlockBtn">Unlock Scores</button>
          </div>

          <div class="lock-status" id="lockStatus">
            Scoreboard is currently locked. Observers may view, but may not interfere.
          </div>
        </div>

        <div>
          <div class="admin-chip hidden" id="adminChip">Admin Mode Active</div>
          <h3>Update Rules</h3>
          <div class="sub-note" style="margin-bottom:0;">
            While locked, all score buttons and reset are disabled. The duck game still works, because morale
            remains mission-critical regardless of access privileges.
          </div>
        </div>
      </div>
    </section>

    <section class="scoreboard" id="scoreboardWrap">
      <article class="score-card pixel-box dalton-card glow-dalton" id="daltonCard">
        <div class="scanline"></div>
        <div class="identity-badge">Department of Strategic Correctness</div>
        <h2 id="daltonTitle">Dalton Was Right</h2>
        <div class="score-meta">
          KPI: confirmed accuracy events, remembered details, and suspiciously confident emails.
        </div>
        <div class="score-value" id="daltonScore">0</div>
        <div class="controls">
          <button class="btn-dalton score-action" id="plusDalton">+1 Dalton</button>
          <button class="btn-dalton score-action" id="minusDalton">-1 Dalton</button>
        </div>
        <div class="locked-overlay" id="daltonLockHint">
          Score controls locked pending authorized code entry.
        </div>
      </article>

      <article class="score-card pixel-box liz-card glow-liz" id="lizCard">
        <div class="scanline"></div>
        <div class="identity-badge">Office Evidence Review Unit</div>
        <h2 id="lizTitle">Liz Was Right</h2>
        <div class="score-meta">
          KPI: decisive receipts, calm corrections, and high-impact “actually...” moments.
        </div>
        <div class="score-value" id="lizScore">0</div>
        <div class="controls">
          <button class="btn-liz score-action" id="plusLiz">+1 Liz</button>
          <button class="btn-liz score-action" id="minusLiz">-1 Liz</button>
        </div>
        <div class="locked-overlay" id="lizLockHint">
          Score controls locked pending authorized code entry.
        </div>
      </article>
    </section>

    <button class="btn-accent btn-reset pixel-box score-action" id="resetBtn">Reset Both Counters</button>

    <section class="dashboard-grid">
      <section class="panel pixel-box">
        <div class="scanline"></div>
        <h3>Recent Activity Log</h3>
        <div class="sub-note">
          Internal audit trail of every official change. This version starts with a fresh cleared log.
        </div>
        <ul class="activity-log" id="activityLog"></ul>
      </section>

      <section class="panel pixel-box">
        <div class="scanline"></div>
        <div class="duck-header">
          <h3 style="margin:0;">Break Room Duck Feeding Arena</h3>
          <div class="duck-stats">
            <div class="duck-stat" id="duckFeedCount">Feeds: 0</div>
            <div class="duck-stat" id="duckMood">Mood: Bloodthirsty For Breadcrumbs</div>
            <div class="duck-stat" id="duckLeader">Top Duck: None</div>
          </div>
        </div>

        <div class="sub-note">
          Tap anywhere to throw food. Ducks sprint, compete, grow when they eat, and crown a temporary snack champion.
        </div>

        <div class="duck-area-wrap">
          <div class="duck-area" id="duckArea" aria-label="Duck feeding game area"></div>
        </div>

        <div class="duck-instructions">
          Tip: stack food fast and watch them fight over it like it’s performance review season.
        </div>
      </section>
    </section>

    <section class="dashboard-grid">
      <section class="panel pixel-box">
        <div class="scanline"></div>
        <h3>Performance Review Summary</h3>
        <div class="status-board">
          <div class="status-card">
            <div class="status-label">Leader Status</div>
            <div class="status-value" id="leaderMini">Nobody has submitted evidence yet.</div>
          </div>

          <div class="status-card">
            <div class="status-label">Match Condition</div>
            <div class="status-value" id="matchState">Stable office tension.</div>
          </div>

          <div class="status-card">
            <div class="status-label">Achievement Badges</div>
            <div class="achievements" id="badgesWrap">
              <div class="badge" id="badgeStreak">Streak Mode</div>
              <div class="badge" id="badgeEvidence">Evidence Overload</div>
              <div class="badge" id="badgeLegend">Office Legend</div>
            </div>
          </div>
        </div>
      </section>

      <section class="panel pixel-box">
        <div class="scanline"></div>
        <h3>Hidden Keyboard Shortcuts</h3>
        <div class="shortcut-list">
          <div><kbd>D</kbd> Dalton +1</div>
          <div><kbd>L</kbd> Liz +1</div>
          <div><kbd>Shift</kbd> + <kbd>D</kbd> Dalton -1</div>
          <div><kbd>Shift</kbd> + <kbd>L</kbd> Liz -1</div>
          <div><kbd>R</kbd> Reset</div>
          <div><kbd>F</kbd> Force Final Round Mode</div>
          <div><kbd>U</kbd> Focus unlock input</div>
          <div><kbd>C</kbd> Clear activity log</div>
        </div>
        <div class="sub-note" style="margin-top:10px; margin-bottom:0;">
          Score shortcuts only work while admin mode is unlocked. Secret logo still toggles drama because office lore outranks policy.
        </div>
      </section>
    </section>

    <div class="footer-note">
      Retro Office Rivalry Console • Mobile-optimized • Includes localStorage persistence, lock code, and competitive growth ducks
    </div>
  </main>

  <script>
    /* =========================================================
       CONFIGURATION
       ========================================================= */
    const CONFIG = {
      people: {
        dalton: { name: "Dalton", storageKey: "arcade_rightness_dalton" },
        liz: { name: "Liz", storageKey: "arcade_rightness_liz" }
      },
      secretCode: "8675309",
      lockStorageKey: "arcade_rightness_unlocked",
      logKey: "arcade_rightness_log",
      forcedFinalRoundKey: "arcade_rightness_forced_final_round",
      maxLogItems: 12,
      clearLogOnLoad: true, // changed per request
      milestones: [10, 25, 50],
      funnyMessages: [
        "The committee has ruled in Dalton's favor.",
        "Liz submits overwhelming evidence.",
        "HR is monitoring this situation.",
        "Productivity may be impacted.",
        "The council has reviewed the evidence.",
        "A strongly worded spreadsheet has entered the chat.",
        "Minutes from the meeting are suddenly very important.",
        "This result will be referenced in future debates.",
        "Compliance has chosen not to comment.",
        "An executive summary is being drafted with concern."
      ],
      easterEggMessages: [
        "SECRET UNLOCKED: THE AUDITORS ARE IMPRESSED.",
        "BONUS ROUND: OFFICE POLITICS DETECTED.",
        "PIXEL PROTOCOL ENGAGED.",
        "RETRO COMPLIANCE MODE ACTIVATED."
      ],
      duckGame: {
        storageKeyFeedCount: "arcade_duck_feed_count",
        storageKeyDuckResults: "arcade_duck_results",
        duckCount: 4,
        foodLifetimeMs: 3000,
        baseScale: 1,
        growthPerSnack: 0.08,
        maxScale: 1.8,
        moodMessages: [
          "Curious",
          "Snack Alert",
          "Territorial",
          "Competitive",
          "Absolute Gremlins",
          "Bread-Fueled Chaos"
        ]
      }
    };

    /* =========================================================
       DOM REFERENCES
       ========================================================= */
    const dom = {
      daltonScore: document.getElementById("daltonScore"),
      lizScore: document.getElementById("lizScore"),
      plusDalton: document.getElementById("plusDalton"),
      minusDalton: document.getElementById("minusDalton"),
      plusLiz: document.getElementById("plusLiz"),
      minusLiz: document.getElementById("minusLiz"),
      resetBtn: document.getElementById("resetBtn"),
      leaderBanner: document.getElementById("leaderBanner"),
      closeMatchPill: document.getElementById("closeMatchPill"),
      differencePill: document.getElementById("differencePill"),
      funnyStatus: document.getElementById("funnyStatus"),
      activityLog: document.getElementById("activityLog"),
      leaderMini: document.getElementById("leaderMini"),
      matchState: document.getElementById("matchState"),
      badgeStreak: document.getElementById("badgeStreak"),
      badgeEvidence: document.getElementById("badgeEvidence"),
      badgeLegend: document.getElementById("badgeLegend"),
      confettiLayer: document.getElementById("confettiLayer"),
      flashOverlay: document.getElementById("flashOverlay"),
      scoreboardWrap: document.getElementById("scoreboardWrap"),
      daltonCard: document.getElementById("daltonCard"),
      lizCard: document.getElementById("lizCard"),
      secretLogo: document.getElementById("secretLogo"),
      easterToast: document.getElementById("easterToast"),
      codeInput: document.getElementById("codeInput"),
      unlockBtn: document.getElementById("unlockBtn"),
      lockStatus: document.getElementById("lockStatus"),
      adminChip: document.getElementById("adminChip"),
      duckArea: document.getElementById("duckArea"),
      duckFeedCount: document.getElementById("duckFeedCount"),
      duckMood: document.getElementById("duckMood"),
      duckLeader: document.getElementById("duckLeader")
    };

    /* =========================================================
       APP STATE
       ========================================================= */
    let state = {
      dalton: 0,
      liz: 0,
      log: [],
      forcedFinalRound: false,
      lastAction: null,
      streakCounter: 0,
      unlocked: false,
      duckFeedCount: 0,
      ducks: [],
      foods: [],
      duckResults: {}
    };

    /* =========================================================
       LOCAL STORAGE HELPERS
       ========================================================= */
    function loadNumber(key) {
      const value = localStorage.getItem(key);
      return value === null ? 0 : Number(value);
    }

    function saveScores() {
      localStorage.setItem(CONFIG.people.dalton.storageKey, String(state.dalton));
      localStorage.setItem(CONFIG.people.liz.storageKey, String(state.liz));
    }

    function saveLog() {
      localStorage.setItem(CONFIG.logKey, JSON.stringify(state.log));
    }

    function saveForcedFinalRound() {
      localStorage.setItem(CONFIG.forcedFinalRoundKey, JSON.stringify(state.forcedFinalRound));
    }

    function saveUnlockState() {
      localStorage.setItem(CONFIG.lockStorageKey, JSON.stringify(state.unlocked));
    }

    function saveDuckFeedCount() {
      localStorage.setItem(CONFIG.duckGame.storageKeyFeedCount, String(state.duckFeedCount));
    }

    function saveDuckResults() {
      localStorage.setItem(CONFIG.duckGame.storageKeyDuckResults, JSON.stringify(state.duckResults));
    }

    function loadState() {
      state.dalton = loadNumber(CONFIG.people.dalton.storageKey);
      state.liz = loadNumber(CONFIG.people.liz.storageKey);
      state.duckFeedCount = loadNumber(CONFIG.duckGame.storageKeyFeedCount);

      try {
        const savedLog = JSON.parse(localStorage.getItem(CONFIG.logKey) || "[]");
        state.log = Array.isArray(savedLog) ? savedLog : [];
      } catch {
        state.log = [];
      }

      try {
        state.forcedFinalRound = JSON.parse(localStorage.getItem(CONFIG.forcedFinalRoundKey) || "false");
      } catch {
        state.forcedFinalRound = false;
      }

      try {
        state.unlocked = JSON.parse(localStorage.getItem(CONFIG.lockStorageKey) || "false");
      } catch {
        state.unlocked = false;
      }

      try {
        const savedResults = JSON.parse(localStorage.getItem(CONFIG.duckGame.storageKeyDuckResults) || "{}");
        state.duckResults = savedResults && typeof savedResults === "object" ? savedResults : {};
      } catch {
        state.duckResults = {};
      }

      if (CONFIG.clearLogOnLoad) {
        state.log = [];
        saveLog();
      }
    }

    /* =========================================================
       UTILITY HELPERS
       ========================================================= */
    function clampToZero(value) {
      return Math.max(0, value);
    }

    function randomItem(arr) {
      return arr[Math.floor(Math.random() * arr.length)];
    }

    function formatTime(date = new Date()) {
      return date.toLocaleTimeString([], { hour: "numeric", minute: "2-digit" });
    }

    function difference() {
      return Math.abs(state.dalton - state.liz);
    }

    function getLeader() {
      if (state.dalton > state.liz) return "dalton";
      if (state.liz > state.dalton) return "liz";
      return "tie";
    }

    function isCloseMatch() {
      return difference() <= 2 && (state.dalton > 0 || state.liz > 0);
    }

    function shouldShowShowdown() {
      return state.forcedFinalRound || (difference() <= 1 && (state.dalton + state.liz) >= 4);
    }

    function canEditScores() {
      return state.unlocked;
    }

    /* =========================================================
       ACTIVITY LOG
       ========================================================= */
    function addLogEntry(type, text) {
      state.log.unshift({
        type,
        text,
        time: formatTime()
      });

      state.log = state.log.slice(0, CONFIG.maxLogItems);
      saveLog();
      renderLog();
    }

    function clearActivityLog() {
      state.log = [];
      saveLog();
      renderLog();
      setFunnyStatus("Activity log cleared. Historical drama has been erased.");
      showToast("ACTIVITY LOG CLEARED");
    }

    function renderLog() {
      dom.activityLog.innerHTML = "";

      if (state.log.length === 0) {
        const li = document.createElement("li");
        li.innerHTML = '<span class="tag system">System</span>Log cleared. No fresh incidents, accusations, or triumphant corrections recorded yet.';
        dom.activityLog.appendChild(li);
        return;
      }

      state.log.forEach(entry => {
        const li = document.createElement("li");
        const tagClass = entry.type === "dalton" ? "dalton" : entry.type === "liz" ? "liz" : "system";
        const tagLabel = entry.type === "dalton"
          ? CONFIG.people.dalton.name
          : entry.type === "liz"
          ? CONFIG.people.liz.name
          : "System";

        li.innerHTML = `
          <span class="tag ${tagClass}">${tagLabel}</span>
          ${entry.text}
          <span class="time">${entry.time}</span>
        `;
        dom.activityLog.appendChild(li);
      });
    }

    /* =========================================================
       LOCK / UNLOCK LOGIC
       ========================================================= */
    function setUnlocked(value) {
      state.unlocked = value;
      saveUnlockState();
      renderLockState();
    }

    function attemptUnlock() {
      const code = dom.codeInput.value.trim();

      if (code === CONFIG.secretCode) {
        setUnlocked(true);
        dom.codeInput.value = "";
        dom.lockStatus.className = "lock-status ok";
        dom.lockStatus.textContent = "Admin mode enabled. Authorized score changes are now available.";
        addLogEntry("system", "Scoreboard unlocked by authorized code entry.");
        setFunnyStatus("Administrative override approved.");
        showToast("ADMIN MODE ENABLED");
      } else {
        dom.lockStatus.className = "lock-status bad";
        dom.lockStatus.textContent = "Incorrect code. The scoreboard remains under strict procedural control.";
        setFunnyStatus("Unauthorized rightness editing attempt denied.");
        showToast("ACCESS DENIED");
      }

      renderScoreButtons();
    }

    function renderLockState() {
      dom.adminChip.classList.toggle("hidden", !state.unlocked);

      if (state.unlocked) {
        dom.lockStatus.className = "lock-status ok";
        dom.lockStatus.textContent = "Admin mode enabled. Authorized score changes are now available.";
      } else {
        dom.lockStatus.className = "lock-status";
        dom.lockStatus.textContent = "Scoreboard is currently locked. Observers may view, but may not interfere.";
      }

      renderScoreButtons();
    }

    function renderScoreButtons() {
      document.querySelectorAll(".score-action").forEach(btn => {
        btn.disabled = !canEditScores();
      });

      document.getElementById("daltonLockHint").classList.toggle("hidden", canEditScores());
      document.getElementById("lizLockHint").classList.toggle("hidden", canEditScores());
    }

    function requireUnlock(actionFn) {
      if (!canEditScores()) {
        dom.lockStatus.className = "lock-status bad";
        dom.lockStatus.textContent = "Scoreboard locked. Enter the admin code to enable updates.";
        showToast("SCOREBOARD LOCKED");
        setFunnyStatus("Governance has blocked unauthorized score tampering.");
        return;
      }
      actionFn();
    }

    /* =========================================================
       SCOREBOARD LOGIC
       ========================================================= */
    function updateScore(person, amount) {
      if (person === "dalton") {
        state.dalton = clampToZero(state.dalton + amount);
      } else {
        state.liz = clampToZero(state.liz + amount);
      }

      if (state.lastAction === person) {
        state.streakCounter += 1;
      } else {
        state.lastAction = person;
        state.streakCounter = 1;
      }

      saveScores();

      const amountLabel = amount > 0 ? `+${amount}` : `${amount}`;
      const personName = CONFIG.people[person].name;

      addLogEntry(person, `${personName} ${amountLabel}`);
      setFunnyStatus();
      checkMilestone(person);
      render();
    }

    function resetScores() {
      state.dalton = 0;
      state.liz = 0;
      state.lastAction = null;
      state.streakCounter = 0;
      state.forcedFinalRound = false;

      saveScores();
      saveForcedFinalRound();

      addLogEntry("system", "Both counters reset. Corporate memory has been selectively cleared.");
      dom.funnyStatus.textContent = "A new fiscal quarter of being right has begun.";
      render();
    }

    /* =========================================================
       LEADER / MATCH STATE
       ========================================================= */
    function renderLeader() {
      const leader = getLeader();

      if (leader === "dalton") {
        dom.leaderBanner.innerHTML = `<strong>${CONFIG.people.dalton.name}</strong> is winning the official correctness race.`;
        dom.leaderMini.textContent = `${CONFIG.people.dalton.name} currently leads the meeting recap narrative.`;
      } else if (leader === "liz") {
        dom.leaderBanner.innerHTML = `<strong>${CONFIG.people.liz.name}</strong> is winning the official correctness race.`;
        dom.leaderMini.textContent = `${CONFIG.people.liz.name} currently controls the evidence pipeline.`;
      } else {
        dom.leaderBanner.innerHTML = `<strong>It's a tie.</strong> The office remains in unstable equilibrium.`;
        dom.leaderMini.textContent = "Neither side has secured a decisive memo-worthy advantage.";
      }
    }

    function renderMatchState() {
      const gap = difference();
      dom.differencePill.textContent = `Difference: ${gap}`;

      dom.closeMatchPill.classList.remove("warning", "showdown");

      if (shouldShowShowdown()) {
        dom.closeMatchPill.textContent = "FINAL ROUND: This is officially too close for comfort.";
        dom.closeMatchPill.classList.add("showdown");
        dom.matchState.textContent = "Critical office showdown. Please secure all spreadsheets and opinions.";
      } else if (isCloseMatch()) {
        dom.closeMatchPill.textContent = "Close Match: managerial concern rising.";
        dom.closeMatchPill.classList.add("warning");
        dom.matchState.textContent = "Margins are dangerously small. Rivalry intensity increasing.";
      } else {
        dom.closeMatchPill.textContent = "Gap Analysis: normal levels of playful tension.";
        dom.matchState.textContent = "Competitive, but not yet requiring a dramatic post-mortem.";
      }

      dom.scoreboardWrap.classList.toggle("showdown-mode", shouldShowShowdown());
      toggleSiren(shouldShowShowdown());
    }

    function toggleSiren(show) {
      document.querySelectorAll(".siren").forEach(el => el.remove());

      if (!show) return;

      [dom.daltonCard, dom.lizCard].forEach(card => {
        const siren = document.createElement("div");
        siren.className = "siren blink";
        siren.textContent = "Final Round";
        card.appendChild(siren);
      });
    }

    /* =========================================================
       FUNNY STATUS / MESSAGES
       ========================================================= */
    function setFunnyStatus(customText) {
      dom.funnyStatus.textContent = customText || randomItem(CONFIG.funnyMessages);
    }

    /* =========================================================
       ACHIEVEMENTS
       ========================================================= */
    function renderBadges() {
      const total = state.dalton + state.liz;
      const leader = getLeader();
      const leaderScore = leader === "dalton" ? state.dalton : leader === "liz" ? state.liz : 0;

      dom.badgeStreak.classList.toggle("active", state.streakCounter >= 3);
      dom.badgeEvidence.classList.toggle("active", leaderScore >= 10);
      dom.badgeLegend.classList.toggle("active", total >= 25);
    }

    /* =========================================================
       CONFETTI / CELEBRATIONS
       ========================================================= */
    function checkMilestone(person) {
      const score = state[person];
      if (!CONFIG.milestones.includes(score)) return;

      const personName = CONFIG.people[person].name;
      addLogEntry("system", `${personName} hit milestone ${score}. Arcade celebration protocol engaged.`);
      setFunnyStatus(`${personName} reached ${score}. The office legend grows.`);
      celebrate(person);
    }

    function celebrate(person) {
      flashScreen();
      spawnConfetti(person);
      // Placeholder for future sound effects
    }

    function flashScreen() {
      dom.flashOverlay.classList.remove("active");
      void dom.flashOverlay.offsetWidth;
      dom.flashOverlay.classList.add("active");
    }

    function spawnConfetti(person) {
      const colorA = person === "dalton" ? "var(--dalton)" : "var(--liz)";
      const colorB = "var(--accent)";
      const pieces = 42;

      for (let i = 0; i < pieces; i++) {
        const bit = document.createElement("div");
        bit.className = "confetti";
        bit.style.left = `${Math.random() * 100}vw`;
        bit.style.background = Math.random() > 0.5 ? colorA : colorB;
        bit.style.animationDuration = `${3 + Math.random() * 2.5}s`;
        bit.style.animationDelay = `${Math.random() * 0.2}s`;
        bit.style.transform = `translateY(0) rotate(${Math.random() * 180}deg)`;
        dom.confettiLayer.appendChild(bit);
        setTimeout(() => bit.remove(), 6000);
      }
    }

    /* =========================================================
       EASTER EGGS / SHORTCUTS
       ========================================================= */
    function showToast(message) {
      dom.easterToast.textContent = message;
      dom.easterToast.classList.remove("show");
      void dom.easterToast.offsetWidth;
      dom.easterToast.classList.add("show");
    }

    function triggerSecretLogo() {
      state.forcedFinalRound = !state.forcedFinalRound;
      saveForcedFinalRound();

      const msg = state.forcedFinalRound
        ? "SECRET MODE: FINAL ROUND ENFORCED."
        : randomItem(CONFIG.easterEggMessages);

      showToast(msg);
      setFunnyStatus(msg);
      addLogEntry("system", msg);
      flashScreen();
      render();
    }

    function handleKeyboardShortcuts(event) {
      const key = event.key.toLowerCase();
      const tag = document.activeElement?.tagName;
      if (tag === "INPUT" || tag === "TEXTAREA") {
        if (key !== "enter") return;
      }

      if (key === "u") {
        dom.codeInput.focus();
        dom.codeInput.select?.();
      }

      if (key === "enter" && document.activeElement === dom.codeInput) {
        attemptUnlock();
      }

      if (key === "f") {
        state.forcedFinalRound = !state.forcedFinalRound;
        saveForcedFinalRound();
        addLogEntry("system", `Final Round mode ${state.forcedFinalRound ? "enabled" : "disabled"} by mysterious keyboard authority.`);
        setFunnyStatus(state.forcedFinalRound ? "Manual override: FINAL ROUND." : "Manual override removed. Tension downgraded.");
        render();
      }

      if (key === "c") {
        clearActivityLog();
      }

      if (!canEditScores()) return;

      if (key === "d" && !event.shiftKey) updateScore("dalton", 1);
      if (key === "l" && !event.shiftKey) updateScore("liz", 1);
      if (key === "d" && event.shiftKey) updateScore("dalton", -1);
      if (key === "l" && event.shiftKey) updateScore("liz", -1);
      if (key === "r") resetScores();
    }

    /* =========================================================
       DUCK GAME
       Ducks are now:
       - bigger
       - competitive
       - grow after eating
       - race individually for specific food
       ========================================================= */
    function createDuckElement(name, colorClass) {
      const duck = document.createElement("div");
      duck.className = `duck ${colorClass}`;
      duck.innerHTML = `
        <div class="duck-badge">${name}</div>
        <div class="duck-body"></div>
        <div class="duck-wing"></div>
        <div class="duck-head">
          <div class="duck-eye"></div>
          <div class="duck-beak"></div>
        </div>
        <div class="duck-foot left"></div>
        <div class="duck-foot right"></div>
      `;
      return duck;
    }

    function initDuckGame() {
      dom.duckArea.innerHTML = "";
      state.ducks = [];
      state.foods = [];

      const rect = dom.duckArea.getBoundingClientRect();
      const width = rect.width || 320;
      const height = rect.height || 260;
      const names = ["BOSS", "MENACE", "UNIT", "CEO"];

      for (let i = 0; i < CONFIG.duckGame.duckCount; i++) {
        const duckEl = createDuckElement(names[i] || `DUCK ${i + 1}`, i === 0 ? "duck-a" : i === 1 ? "duck-b" : i === 2 ? "duck-c" : "duck-d");

        const previousScore = state.duckResults[i]?.eaten || 0;
        const previousScale = Math.min(
          CONFIG.duckGame.baseScale + previousScore * CONFIG.duckGame.growthPerSnack,
          CONFIG.duckGame.maxScale
        );

        const duck = {
          id: i,
          name: names[i] || `DUCK ${i + 1}`,
          x: 70 + (i * (width / (CONFIG.duckGame.duckCount + 0.7))),
          y: height * 0.74 + (i % 2) * 12,
          targetX: 70 + (i * (width / (CONFIG.duckGame.duckCount + 0.7))),
          targetY: height * 0.74 + (i % 2) * 12,
          speed: 1.1 + Math.random() * 0.55 + previousScore * 0.02,
          scale: previousScale,
          eaten: previousScore,
          foodTargetId: null,
          el: duckEl
        };

        duckEl.style.setProperty("--duck-scale", duck.scale.toFixed(2));
        dom.duckArea.appendChild(duckEl);
        state.ducks.push(duck);
        positionDuck(duck);
      }

      renderDuckStats();
      updateDuckChampion();
    }

    function positionDuck(duck) {
      duck.el.style.left = `${duck.x}px`;
      duck.el.style.top = `${duck.y}px`;
    }

    function getDistance(ax, ay, bx, by) {
      return Math.hypot(ax - bx, ay - by);
    }

    function assignTargetsCompetitively() {
      if (state.foods.length === 0) {
        state.ducks.forEach((duck, index) => {
          duck.foodTargetId = null;
          duck.targetX = 80 + index * 60;
        });
        return;
      }

      state.ducks.forEach(duck => {
        let bestFood = state.foods[0];
        let bestScore = Infinity;

        state.foods.forEach(food => {
          const distance = getDistance(duck.x, duck.y, food.x, food.y);
          const greedBonus = duck.eaten * 2.2;
          const score = distance - greedBonus;
          if (score < bestScore) {
            bestScore = score;
            bestFood = food;
          }
        });

        duck.foodTargetId = bestFood.id;
        duck.targetX = bestFood.x;
        duck.targetY = bestFood.y + 10;
      });
    }

    function spawnFood(clientX, clientY) {
      const rect = dom.duckArea.getBoundingClientRect();
      const x = Math.max(16, Math.min(rect.width - 16, clientX - rect.left));
      const y = Math.max(24, Math.min(rect.height - 20, clientY - rect.top));

      const foodEl = document.createElement("div");
      foodEl.className = "food";
      foodEl.textContent = "✦";
      foodEl.style.left = `${x}px`;
      foodEl.style.top = `${y}px`;

      dom.duckArea.appendChild(foodEl);

      const food = {
        id: `food_${Date.now()}_${Math.random().toString(36).slice(2, 6)}`,
        x,
        y,
        el: foodEl,
        createdAt: Date.now()
      };

      state.foods.push(food);
      state.duckFeedCount += 1;
      saveDuckFeedCount();
      renderDuckStats();
      assignTargetsCompetitively();

      setTimeout(() => {
        if (!state.foods.includes(food)) return;
        foodEl.remove();
        state.foods = state.foods.filter(item => item !== food);
        assignTargetsCompetitively();
      }, CONFIG.duckGame.foodLifetimeMs);
    }

    function renderDuckStats() {
      dom.duckFeedCount.textContent = `Feeds: ${state.duckFeedCount}`;

      if (state.duckFeedCount === 0) {
        dom.duckMood.textContent = "Mood: Bloodthirsty For Breadcrumbs";
      } else if (state.duckFeedCount < 8) {
        dom.duckMood.textContent = "Mood: Snack Alert";
      } else if (state.duckFeedCount < 20) {
        dom.duckMood.textContent = "Mood: Territorial";
      } else if (state.duckFeedCount < 40) {
        dom.duckMood.textContent = "Mood: Competitive";
      } else {
        dom.duckMood.textContent = "Mood: Bread-Fueled Chaos";
      }

      const champion = getDuckChampion();
      dom.duckLeader.textContent = champion
        ? `Top Duck: ${champion.name} (${champion.eaten})`
        : "Top Duck: None";
    }

    function getDuckChampion() {
      if (state.ducks.length === 0) return null;
      return [...state.ducks].sort((a, b) => b.eaten - a.eaten)[0];
    }

    function updateDuckChampion() {
      const champion = getDuckChampion();
      state.ducks.forEach(duck => {
        duck.el.classList.toggle("duck-champion", champion && champion.id === duck.id);
      });
    }

    function makeDuckGrow(duck) {
      duck.scale = Math.min(duck.scale + CONFIG.duckGame.growthPerSnack, CONFIG.duckGame.maxScale);
      duck.el.style.setProperty("--duck-scale", duck.scale.toFixed(2));
    }

    function sparkBurst(x, y) {
      for (let i = 0; i < 6; i++) {
        const spark = document.createElement("div");
        spark.className = "duck-spark";
        spark.textContent = i % 2 === 0 ? "✦" : "•";
        spark.style.left = `${x}px`;
        spark.style.top = `${y}px`;
        spark.style.setProperty("--dx", `${(Math.random() * 50 - 25).toFixed(0)}px`);
        spark.style.setProperty("--dy", `${(Math.random() * 50 - 25).toFixed(0)}px`);
        dom.duckArea.appendChild(spark);
        setTimeout(() => spark.remove(), 700);
      }
    }

    function maybeShowDuckHappyText(duck, text = null) {
      const bubble = document.createElement("div");
      bubble.className = "duck-happy";
      bubble.textContent = text || randomItem(["MINE", "CHOMP", "+1 MASS", "UNSTOPPABLE", "NO MERCY"]);
      duck.el.appendChild(bubble);
      setTimeout(() => bubble.remove(), 900);
    }

    function handleDuckEating() {
      state.ducks.forEach(duck => {
        const targetFood = state.foods.find(food => food.id === duck.foodTargetId);
        if (!targetFood) return;

        const distance = getDistance(duck.x, duck.y, targetFood.x, targetFood.y);

        duck.el.classList.toggle("duck-rush", distance < 120);

        if (distance < 18) {
          targetFood.el.remove();
          state.foods = state.foods.filter(food => food !== targetFood);

          duck.eaten += 1;
          state.duckResults[duck.id] = { eaten: duck.eaten };
          saveDuckResults();

          duck.speed = Math.min(duck.speed + 0.04, 2.45);
          makeDuckGrow(duck);
          maybeShowDuckHappyText(duck);
          sparkBurst(targetFood.x, targetFood.y);
          updateDuckChampion();
          renderDuckStats();
          assignTargetsCompetitively();

          if (duck.eaten === 5 || duck.eaten === 10 || duck.eaten === 20) {
            showToast(`${duck.name} HIT ${duck.eaten} SNACKS`);
          }
        }
      });
    }

    function animateDucks() {
      state.ducks.forEach((duck, index) => {
        const dx = duck.targetX - duck.x;
        const dy = duck.targetY - duck.y;
        const distance = Math.hypot(dx, dy);

        if (distance > 1) {
          duck.x += (dx / distance) * duck.speed;
          duck.y += (dy / distance) * duck.speed;

          duck.el.classList.toggle("flip", dx < 0);
          positionDuck(duck);
        } else if (state.foods.length === 0) {
          duck.targetY = duck.y + Math.sin(Date.now() / 450 + index) * 0.3;
        }
      });

      handleDuckEating();
      requestAnimationFrame(animateDucks);
    }

    function handleDuckAreaPointer(event) {
      const point = event.touches ? event.touches[0] : event;
      spawnFood(point.clientX, point.clientY);
    }

    /* =========================================================
       RENDER
       ========================================================= */
    function renderScores() {
      dom.daltonScore.textContent = state.dalton;
      dom.lizScore.textContent = state.liz;
    }

    function render() {
      renderScores();
      renderLeader();
      renderMatchState();
      renderBadges();
      renderLockState();
      renderDuckStats();
    }

    /* =========================================================
       EVENT BINDINGS
       ========================================================= */
    dom.plusDalton.addEventListener("click", () => requireUnlock(() => updateScore("dalton", 1)));
    dom.minusDalton.addEventListener("click", () => requireUnlock(() => updateScore("dalton", -1)));
    dom.plusLiz.addEventListener("click", () => requireUnlock(() => updateScore("liz", 1)));
    dom.minusLiz.addEventListener("click", () => requireUnlock(() => updateScore("liz", -1)));
    dom.resetBtn.addEventListener("click", () => requireUnlock(resetScores));

    dom.unlockBtn.addEventListener("click", attemptUnlock);
    dom.codeInput.addEventListener("keydown", (event) => {
      if (event.key === "Enter") attemptUnlock();
    });

    dom.secretLogo.addEventListener("click", triggerSecretLogo);
    window.addEventListener("keydown", handleKeyboardShortcuts);

    dom.duckArea.addEventListener("click", handleDuckAreaPointer);
    dom.duckArea.addEventListener("touchstart", handleDuckAreaPointer, { passive: true });

    window.addEventListener("resize", () => {
      initDuckGame();
    });

    /* =========================================================
       INITIALIZE APP
       ========================================================= */
    loadState();
    renderLog();

    if (state.log.length === 0) {
      setFunnyStatus("Activity log reset. Fresh drama may now begin.");
    } else {
      setFunnyStatus("Historical records loaded from the vault.");
    }

    initDuckGame();
    animateDucks();
    render();
  </script>
</body>
</html>
